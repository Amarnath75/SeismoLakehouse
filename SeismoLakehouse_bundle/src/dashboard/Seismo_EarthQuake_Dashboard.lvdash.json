{
  "datasets": [
    {
      "name": "9f029477",
      "displayName": "EarthQuake_details",
      "queryLines": [
        "Select * from silver.earthquake_data_final"
      ],
      "catalog": "youtube_dev",
      "schema": "default"
    },
    {
      "name": "062e6354",
      "displayName": "Earthquake_type",
      "queryLines": [
        "select\r\n",
        "  count(*) as total_magnitude_bucket,\r\n",
        "  magnitude_bucket\r\n",
        "from\r\n",
        "  (\r\n",
        "    select\r\n",
        "      CASE\r\n",
        "        WHEN mag < 2 THEN 'Micro (<2)'\r\n",
        "        WHEN mag BETWEEN 2 AND 3 THEN 'Minor (2-3)'\r\n",
        "        WHEN mag BETWEEN 3 AND 4 THEN 'Light (3-4)'\r\n",
        "        ELSE 'Moderate+ (4+)'\r\n",
        "      END as magnitude_bucket\r\n",
        "    from\r\n",
        "      silver.earthquake_data_final\r\n",
        "  )\r\n",
        "group by\r\n",
        "  magnitude_bucket"
      ],
      "catalog": "youtube_dev",
      "schema": "silver"
    },
    {
      "name": "56eac659",
      "displayName": "Earthquake.country",
      "queryLines": [
        "SELECT\r\n",
        "  count(*) AS event_count,\r\n",
        "  get(split(place, ','), 1) AS country\r\n",
        "FROM\r\n",
        "  (\r\n",
        "    SELECT\r\n",
        "      time,\r\n",
        "      title,\r\n",
        "      mag,\r\n",
        "      longitude,\r\n",
        "      place,\r\n",
        "      latitude\r\n",
        "    FROM\r\n",
        "      silver.earthquake_data_final\r\n",
        "  )\r\n",
        "GROUP BY\r\n",
        "  country"
      ],
      "catalog": "youtube_dev",
      "schema": "silver"
    }
  ],
